<!DOCTYPE html>
<html>
<head>
    <title>FocusFlow Dashboard</title>

    <link rel="stylesheet" href="/css/style.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="container">

    <aside class="sidebar">

        <h2>⚡ FocusFlow</h2>

        <ul>
            <li><a href="/">Dashboard</a></li>
            <li><a href="/tasks">Tasks</a></li>
            <li><a href="/habits">Habits</a></li>
            <li><a href="/analytics">Analytics</a></li>
            <li><a href="/notes">Notes</a></li>
        </ul>

    </aside>

    <main class="main">

        <h1>Welcome Back 👋</h1>

        <div class="cards">

            <div class="card purple">
                <h3>Total Tasks</h3>
                <h1><%= tasks.length %></h1>
            </div>

            <div class="card green">
                <h3>Habits</h3>
                <h1><%= habits.length %></h1>
            </div>

            <div class="card blue">
                <h3>Productivity</h3>
                <h1>85%</h1>
            </div>

            <div class="card orange">
                <h3>Focus Hours</h3>
                <h1>14h</h1>
            </div>

        </div>

        <div class="dashboard-grid">

            <section class="panel">

                <h2>Today's Tasks</h2>

                <% tasks.forEach(task => { %>

                    <div class="item">
                        <h4><%= task.task %></h4>
                        <span><%= task.priority %></span>
                    </div>

                <% }) %>

            </section>

            <section class="panel">

                <h2>Habit Streaks</h2>

                <% habits.forEach(habit => { %>

                    <div class="item">
                        <h4><%= habit.habit %></h4>
                        <span>🔥 <%= habit.streak %> Days</span>
                    </div>

                <% }) %>

            </section>

        </div>

        <section class="panel chart-panel">

            <h2>Weekly Productivity</h2>

            <canvas id="productivityChart"></canvas>

        </section>

        <section class="ai-box">

            🤖 AI Suggestion:
            Complete high-priority tasks before checking social media.

        </section>

    </main>

</div>

<script src="/js/app.js"></script>

</body>
</html>